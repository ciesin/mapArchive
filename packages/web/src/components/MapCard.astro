---
import { getThumbnailUrl } from '../lib/images';

interface Props {
  id: string;
  title: string;
  description?: string | null;
  theme?: string | null;
  admin0?: string | null;
  area?: string | null;
  datetime?: string | null;
  assetHref?: string | null;
}

const { id, title, description, theme, admin0, area, datetime, assetHref } = Astro.props;
const thumbnailSrc = assetHref ? getThumbnailUrl(assetHref) : '';
const dateStr = datetime ? new Date(datetime).getFullYear().toString() : '';
const badgeClass = theme ? `badge badge-${theme}` : 'badge';
---

<a href={`/map/${id}`} class="card">
  <div class="card-image-wrapper">
    {thumbnailSrc ? (
      <img src={thumbnailSrc} alt={title} class="card-image" loading="lazy" />
    ) : (
      <div class="card-image card-image-placeholder"></div>
    )}
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <div class="card-meta">
      {theme && <span class={badgeClass}>{theme}</span>}
      {admin0 && <span class="card-tag">{admin0}</span>}
      {area && <span class="card-tag">{area}</span>}
      {dateStr && <span class="card-tag">{dateStr}</span>}
    </div>
    {description && <p class="card-desc">{description}</p>}
  </div>
</a>

<style>
  a.card {
    color: inherit;
    text-decoration: none;
  }
  .card-image-wrapper {
    overflow: hidden;
  }
  .card-image-placeholder {
    background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
  }
  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }
  .card-tag {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background: var(--color-bg);
    padding: 0.0625rem 0.375rem;
    border-radius: var(--radius);
  }
  .card-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
