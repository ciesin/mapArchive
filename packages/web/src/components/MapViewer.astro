---
import { getDetailUrl, getFullResUrl } from '../lib/images';

interface Props {
  assetHref: string;
  title: string;
}

const { assetHref, title } = Astro.props;
const detailSrc = getDetailUrl(assetHref);
const fullResSrc = getFullResUrl(assetHref);
---

<div class="viewer-wrapper">
  <div class="viewer-toolbar">
    <a href={fullResSrc} target="_blank" rel="noopener" class="btn">
      Full Resolution
    </a>
  </div>
  <div class="map-viewer">
    <img src={detailSrc} alt={title} />
  </div>
</div>

<style>
  .viewer-wrapper {
    margin: 1rem 0;
  }
  .viewer-toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.5rem;
  }
</style>
